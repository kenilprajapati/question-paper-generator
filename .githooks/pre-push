#!/usr/bin/env node

console.log('\n---');
console.log('Git Hook: pre-push');
console.log('Checking database migrations...');
console.log('-------------------------------');

const { spawnSync } = require('child_process');
const path = require('path');

console.log('Running migration and data verification scripts...');

// 1. Run migrations check
const migrationResult = spawnSync('node', [path.join(__dirname, '../backend/scripts/run-migrations.js')], { stdio: 'inherit' });

if (migrationResult.status !== 0) {
  console.error('\nMigration check failed. Push aborted.');
  process.exit(1);
}

// 2. Run export to ensure seeds are updated (backup check)
console.log('\nEnsuring seeds are synchronized...');
spawnSync('node', [path.join(__dirname, '../backend/scripts/export-db.js')], { stdio: 'inherit' });

console.log('Migration completed');
console.log('Database schema verified\n');
process.exit(0);
